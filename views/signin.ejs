<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <title>Sign In</title>
</head>
<body>
    <div class="m-4">
        <h1 class="display-6">Sign In</h1>
        <% if (error) { %> 

            <%# we can directly use locals.error as error also %>
            <%# it is ejs functionality %>
            
            <div class="alert alert-danger" role="alert">
                <%= error %>
            </div>

        <% } %>
        <% if (!error) { %>
        <form action="/signin" method="post">
            <div class="mb-3">
                <label for="email" class="form-label">Email address</label>
                <input type="email" class="form-control w-25" style="border-width: 3px;" id="email" placeholder="name@example.com">
            </div>
            <div class="mb-3">
                <label for="Password" class="form-label">Password</label>
                <input class="form-control w-25" id="password" style="border-width: 3px;" placeholder="Password"></input>
            </div>
            <button type="submit" class="btn btn-outline-dark">Sign In</button>
        </form>
        <% } %>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>